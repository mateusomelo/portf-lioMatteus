# Porta do servidor
PORT=3000

# Chave usada para assinar os tokens JWT do admin (troque por um valor aleatório e secreto)
JWT_SECRET=troque-esta-chave-por-um-segredo-bem-grande-e-aleatorio

# Tempo de expiração do token de login
JWT_EXPIRES_IN=7d

# URL pública do site (usada para checar embeddability corretamente)
SITE_URL=http://localhost:3000
